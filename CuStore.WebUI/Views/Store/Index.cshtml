@model CuStore.WebUI.Models.StoreIndexViewModel
@{
    ViewData["Title"] = "Store";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">Products</h2>
    <a class="btn btn-outline-primary" asp-controller="Store" asp-action="Cart">Cart</a>
</div>

<div class="row g-3">
@foreach (var product in Model.Products)
{
    <div class="col-md-4">
        <div class="card h-100">
            <div class="card-body d-flex flex-column">
                <h5 class="card-title">@product.Name</h5>
                <p class="card-text flex-grow-1">@product.Description</p>
                <p class="mb-2"><strong>@product.Price.ToString("C")</strong></p>
                <form asp-action="AddToCart" method="post" class="d-flex gap-2">
                    <input type="hidden" name="productId" value="@product.Id" />
                    <input type="number" name="quantity" value="1" min="1" class="form-control" style="max-width:100px" />
                    <button type="submit" class="btn btn-primary">Add</button>
                </form>
            </div>
        </div>
    </div>
}
</div>
